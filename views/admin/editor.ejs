<%- include('../partials/head', { pageTitle: update ? 'Edit Update' : 'New Update' }) %>

<section class="admin-editor">
  <a href="/admin" class="back-link">Back to dashboard</a>

  <h1><%= update ? 'Edit Update' : 'New Update' %></h1>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="<%= update ? '/admin/edit/' + update.id : '/admin/new' %>" enctype="multipart/form-data" class="editor-form">
    <div class="form-group">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" value="<%= update ? update.title : '' %>" required placeholder="e.g. Day 12 - Getting Stronger">
    </div>

    <div class="form-group">
      <label for="update_date">Date & Time</label>
      <input type="datetime-local" id="update_date" name="update_date" value="<%= update && update.update_date ? update.update_date.slice(0, 16) : '' %>" required>
    </div>

    <div class="form-group">
      <label for="sentiment">How's she doing? <span id="sentiment-label" style="font-weight:400; color: var(--gray-400);"></span></label>
      <input type="range" id="sentiment" name="sentiment" min="1" max="10" value="<%= update ? update.sentiment || 5 : 5 %>" style="width:100%; accent-color: var(--rose-500);">
      <div style="display:flex; justify-content:space-between; font-size:0.75rem; color:var(--gray-400); margin-top:0.25rem;">
        <span>Rough day</span>
        <span>Amazing day</span>
      </div>
    </div>

    <div class="form-group">
      <label for="content">What happened today?</label>
      <textarea id="content" name="content" rows="10" required placeholder="Tell everyone how <%= settings.baby_name || 'baby' %> is doing today..."><%= update ? update.content : '' %></textarea>
    </div>

    <div class="form-group">
      <label for="photos">Photos (optional)</label>
      <input type="file" id="photos" name="photos" accept="image/*" multiple>
      <div id="new-photo-preview" style="display:none; margin-top: 0.5rem;">
        <p style="font-size: 0.8rem; color: var(--gray-400); margin-bottom: 0.5rem;">Drag to reorder. First photo is the cover.</p>
        <div id="new-photo-grid" style="display: flex; flex-wrap: wrap; gap: 0.75rem;"></div>
      </div>
      <% if (photos && photos.length > 0) { %>
        <p style="font-size: 0.8rem; color: var(--gray-400); margin-top: 0.5rem;">Drag to reorder. First photo is the cover.</p>
        <div id="photo-grid" class="current-photos" style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.5rem;">
          <% photos.forEach(function(p) { %>
            <div class="photo-item" data-id="<%= p.id %>" draggable="true" style="position: relative; cursor: grab;">
              <img src="<%= p.photo %>" alt="Photo" style="max-width: 150px; border-radius: 8px; pointer-events: none;">
              <button type="button" onclick="if(confirm('Delete this photo?')){fetch('/admin/photo/delete/<%= p.id %>',{method:'POST'}).then(()=>this.parentElement.remove())}" style="position: absolute; top: 4px; right: 4px; background: rgba(0,0,0,0.7); color: white; border: none; border-radius: 50%; width: 24px; height: 24px; cursor: pointer; font-size: 14px; line-height: 1;">&times;</button>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <div id="upload-progress" style="display:none; margin-bottom: 1rem;">
      <div style="display:flex; justify-content:space-between; font-size:0.85rem; margin-bottom:0.35rem;">
        <span id="progress-text">Uploading photos...</span>
        <span id="progress-pct">0%</span>
      </div>
      <div style="width:100%; height:6px; background:var(--gray-200, #e5e7eb); border-radius:3px; overflow:hidden;">
        <div id="progress-bar" style="width:0%; height:100%; background:var(--rose-500, #f43f5e); border-radius:3px; transition: width 0.2s ease;"></div>
      </div>
    </div>

    <button type="submit" id="submit-btn" class="btn btn-primary btn-full"><%= update ? 'Save Changes' : 'Post Update' %></button>
  </form>
</section>

<script>
(function() {
  // Set default date/time to local "now" for new updates
  const dateInput = document.getElementById('update_date');
  if (!dateInput.value) {
    const now = new Date();
    const local = new Date(now.getTime() - now.getTimezoneOffset() * 60000);
    dateInput.value = local.toISOString().slice(0, 16);
  }

  const slider = document.getElementById('sentiment');
  const label = document.getElementById('sentiment-label');
  const labels = ['','Very rough','Rough','Hard','Below average','Okay','Decent','Good','Great','Wonderful','Amazing'];
  function update() { label.textContent = '(' + labels[parseInt(slider.value)] + ')'; }
  slider.addEventListener('input', update);
  update();

  const form = document.querySelector('.editor-form');
  const photosInput = document.getElementById('photos');
  const progressWrap = document.getElementById('upload-progress');
  const progressBar = document.getElementById('progress-bar');
  const progressPct = document.getElementById('progress-pct');
  const progressText = document.getElementById('progress-text');
  const submitBtn = document.getElementById('submit-btn');

  // New photo preview with drag-and-drop reordering
  const newPhotoPreview = document.getElementById('new-photo-preview');
  const newPhotoGrid = document.getElementById('new-photo-grid');
  let orderedFiles = []; // tracks files in user's chosen order

  photosInput.addEventListener('change', function() {
    orderedFiles = Array.from(photosInput.files);
    renderNewPhotoPreviews();
  });

  function renderNewPhotoPreviews() {
    newPhotoGrid.innerHTML = '';
    if (!orderedFiles.length) {
      newPhotoPreview.style.display = 'none';
      return;
    }
    newPhotoPreview.style.display = 'block';
    orderedFiles.forEach(function(file, idx) {
      const wrapper = document.createElement('div');
      wrapper.className = 'photo-item';
      wrapper.dataset.idx = idx;
      wrapper.draggable = true;
      wrapper.style.cssText = 'position: relative; cursor: grab;';

      const img = document.createElement('img');
      img.style.cssText = 'max-width: 150px; border-radius: 8px; pointer-events: none;';
      img.alt = file.name;
      const url = URL.createObjectURL(file);
      img.src = url;
      img.onload = function() { URL.revokeObjectURL(url); };

      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.innerHTML = '&times;';
      removeBtn.style.cssText = 'position: absolute; top: 4px; right: 4px; background: rgba(0,0,0,0.7); color: white; border: none; border-radius: 50%; width: 24px; height: 24px; cursor: pointer; font-size: 14px; line-height: 1;';
      removeBtn.addEventListener('click', function() {
        orderedFiles.splice(orderedFiles.indexOf(file), 1);
        renderNewPhotoPreviews();
      });

      wrapper.appendChild(img);
      wrapper.appendChild(removeBtn);
      newPhotoGrid.appendChild(wrapper);
    });
  }

  // Drag-and-drop for new photo previews
  (function() {
    let dragged = null;

    newPhotoGrid.addEventListener('dragstart', function(e) {
      dragged = e.target.closest('.photo-item');
      if (dragged) dragged.style.opacity = '0.4';
    });
    newPhotoGrid.addEventListener('dragend', function() {
      if (dragged) dragged.style.opacity = '1';
      dragged = null;
    });
    newPhotoGrid.addEventListener('dragover', function(e) {
      e.preventDefault();
      const target = e.target.closest('.photo-item');
      if (target && target !== dragged) {
        const items = [...newPhotoGrid.querySelectorAll('.photo-item')];
        const tIdx = items.indexOf(target);
        if (items.indexOf(dragged) < tIdx) {
          newPhotoGrid.insertBefore(dragged, target.nextSibling);
        } else {
          newPhotoGrid.insertBefore(dragged, target);
        }
      }
    });
    newPhotoGrid.addEventListener('drop', function(e) {
      e.preventDefault();
      // Sync orderedFiles to match the new DOM order
      const items = [...newPhotoGrid.querySelectorAll('.photo-item')];
      const newOrder = items.map(function(el) {
        return orderedFiles[parseInt(el.dataset.idx)];
      });
      orderedFiles = newOrder;
      // Update data-idx to match new positions
      items.forEach(function(el, i) { el.dataset.idx = i; });
    });
  })();

  form.addEventListener('submit', function(e) {
    const hasNewFiles = orderedFiles.length > 0;
    if (!hasNewFiles && (!photosInput.files || !photosInput.files.length)) return;
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.textContent = 'Uploading...';
    progressWrap.style.display = 'block';

    const xhr = new XMLHttpRequest();
    xhr.open('POST', form.action);

    xhr.upload.addEventListener('progress', function(ev) {
      if (!ev.lengthComputable) return;
      const pct = Math.round((ev.loaded / ev.total) * 100);
      progressBar.style.width = pct + '%';
      progressPct.textContent = pct + '%';
      if (pct === 100) progressText.textContent = 'Processing...';
    });

    xhr.addEventListener('load', function() {
      window.location.href = '/admin';
    });

    xhr.addEventListener('error', function() {
      submitBtn.disabled = false;
      submitBtn.textContent = '<%= update ? "Save Changes" : "Post Update" %>';
      progressWrap.style.display = 'none';
      alert('Upload failed. Please try again.');
    });

    // Build FormData with files in the user's chosen order
    const fd = new FormData(form);
    fd.delete('photos');
    if (hasNewFiles) {
      orderedFiles.forEach(function(file) { fd.append('photos', file); });
    }
    xhr.send(fd);
  });

  // Drag-and-drop photo reordering (existing server-side photos)
  const grid = document.getElementById('photo-grid');
  if (grid) {
    let dragged = null;
    grid.addEventListener('dragstart', function(e) {
      dragged = e.target.closest('.photo-item');
      if (dragged) dragged.style.opacity = '0.4';
    });
    grid.addEventListener('dragend', function() {
      if (dragged) dragged.style.opacity = '1';
      dragged = null;
    });
    grid.addEventListener('dragover', function(e) {
      e.preventDefault();
      const target = e.target.closest('.photo-item');
      if (target && target !== dragged) {
        const items = [...grid.querySelectorAll('.photo-item')];
        const dragIdx = items.indexOf(dragged);
        const targetIdx = items.indexOf(target);
        if (dragIdx < targetIdx) {
          grid.insertBefore(dragged, target.nextSibling);
        } else {
          grid.insertBefore(dragged, target);
        }
      }
    });
    grid.addEventListener('drop', function(e) {
      e.preventDefault();
      const ids = [...grid.querySelectorAll('.photo-item')].map(el => el.dataset.id);
      fetch('/admin/photos/reorder', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ photoIds: ids })
      });
    });
  }

})();
</script>
<%- include('../partials/footer') %>
