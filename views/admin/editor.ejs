<%- include('../partials/head', { pageTitle: update ? 'Edit Update' : 'New Update' }) %>

<section class="admin-editor">
  <a href="/admin" class="back-link">Back to dashboard</a>

  <h1><%= update ? 'Edit Update' : 'New Update' %></h1>

  <form method="POST" action="<%= update ? '/admin/edit/' + update.id : '/admin/new' %>" enctype="multipart/form-data" class="editor-form">
    <div class="form-group">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" value="<%= update ? update.title : '' %>" required placeholder="e.g. Day 12 - Getting Stronger">
    </div>

    <div class="form-group">
      <label for="update_date">Date & Time</label>
      <input type="datetime-local" id="update_date" name="update_date" value="<%= update && update.update_date ? update.update_date.slice(0, 16) : new Date().toISOString().slice(0, 16) %>" required>
    </div>

    <div class="form-group">
      <label for="sentiment">How's she doing? <span id="sentiment-label" style="font-weight:400; color: var(--gray-400);"></span></label>
      <input type="range" id="sentiment" name="sentiment" min="1" max="10" value="<%= update ? update.sentiment || 5 : 5 %>" style="width:100%; accent-color: var(--rose-500);">
      <div style="display:flex; justify-content:space-between; font-size:0.75rem; color:var(--gray-400); margin-top:0.25rem;">
        <span>Rough day</span>
        <span>Amazing day</span>
      </div>
    </div>

    <div class="form-group">
      <label for="content">What happened today?</label>
      <textarea id="content" name="content" rows="10" required placeholder="Tell everyone how Myla is doing today..."><%= update ? update.content : '' %></textarea>
    </div>

    <div class="form-group">
      <label for="photos">Photos (optional)</label>
      <input type="file" id="photos" name="photos" accept="image/*" multiple>
      <% if (photos && photos.length > 0) { %>
        <div class="current-photos" style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.75rem;">
          <% photos.forEach(function(p) { %>
            <div style="position: relative;">
              <img src="<%= p.photo %>" alt="Photo" style="max-width: 150px; border-radius: 8px;">
              <button type="button" onclick="if(confirm('Delete this photo?')){fetch('/admin/photo/delete/<%= p.id %>',{method:'POST'}).then(()=>this.parentElement.remove())}" style="position: absolute; top: 4px; right: 4px; background: rgba(0,0,0,0.7); color: white; border: none; border-radius: 50%; width: 24px; height: 24px; cursor: pointer; font-size: 14px; line-height: 1;">&times;</button>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <div id="upload-progress" style="display:none; margin-bottom: 1rem;">
      <div style="display:flex; justify-content:space-between; font-size:0.85rem; margin-bottom:0.35rem;">
        <span id="progress-text">Uploading photos...</span>
        <span id="progress-pct">0%</span>
      </div>
      <div style="width:100%; height:6px; background:var(--gray-200, #e5e7eb); border-radius:3px; overflow:hidden;">
        <div id="progress-bar" style="width:0%; height:100%; background:var(--rose-500, #f43f5e); border-radius:3px; transition: width 0.2s ease;"></div>
      </div>
    </div>

    <button type="submit" id="submit-btn" class="btn btn-primary btn-full"><%= update ? 'Save Changes' : 'Post Update' %></button>
  </form>
</section>

<script>
(function() {
  const slider = document.getElementById('sentiment');
  const label = document.getElementById('sentiment-label');
  const labels = ['','Very rough','Rough','Hard','Below average','Okay','Decent','Good','Great','Wonderful','Amazing'];
  function update() { label.textContent = '(' + labels[parseInt(slider.value)] + ')'; }
  slider.addEventListener('input', update);
  update();

  const form = document.querySelector('.editor-form');
  const photosInput = document.getElementById('photos');
  const progressWrap = document.getElementById('upload-progress');
  const progressBar = document.getElementById('progress-bar');
  const progressPct = document.getElementById('progress-pct');
  const progressText = document.getElementById('progress-text');
  const submitBtn = document.getElementById('submit-btn');

  form.addEventListener('submit', function(e) {
    if (!photosInput.files || !photosInput.files.length) return;
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.textContent = 'Uploading...';
    progressWrap.style.display = 'block';

    const xhr = new XMLHttpRequest();
    xhr.open('POST', form.action);

    xhr.upload.addEventListener('progress', function(ev) {
      if (!ev.lengthComputable) return;
      const pct = Math.round((ev.loaded / ev.total) * 100);
      progressBar.style.width = pct + '%';
      progressPct.textContent = pct + '%';
      if (pct === 100) progressText.textContent = 'Processing...';
    });

    xhr.addEventListener('load', function() {
      window.location.href = '/admin';
    });

    xhr.addEventListener('error', function() {
      submitBtn.disabled = false;
      submitBtn.textContent = '<%= update ? "Save Changes" : "Post Update" %>';
      progressWrap.style.display = 'none';
      alert('Upload failed. Please try again.');
    });

    xhr.send(new FormData(form));
  });
})();
</script>
<%- include('../partials/footer') %>
