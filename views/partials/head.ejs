<%
  const _theme = (settings && settings.theme) || 'rose';
  const _logo = (settings && settings.site_logo) || '/images/white-footprint.png';
  const _themeColors = {
    rose: '#e44b6a', ocean: '#0ea5e9', lavender: '#a855f7', sunset: '#f97316', forest: '#10b981',
    'rose-light': '#e44b6a', 'ocean-light': '#0ea5e9', 'lavender-light': '#a855f7', 'sunset-light': '#f97316', 'forest-light': '#10b981',
  };
  const _themeColor = _themeColors[_theme] || '#e44b6a';
  const _babyName = (settings && settings.baby_name) || 'Baby';
%>
<!DOCTYPE html>
<html lang="en" data-theme="<%= _theme %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' - ' : '' %><%= _babyName %>.fyi</title>
  <meta name="description" content="Follow <%= _babyName %>'s journey - born early, growing strong.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css?v=<%= buildVersion %>">
  <link rel="icon" type="image/png" href="<%= _logo %>">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="<%= _themeColor %>">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <link rel="apple-touch-icon" href="<%= _logo %>">
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-VZNGR7YSH3"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-VZNGR7YSH3');
  </script>
</head>
<body>
  <header>
    <nav>
      <a href="/" class="logo"><img src="<%= _logo %>" alt="<%= _babyName %>" class="logo-icon"><span class="logo-text"><%= _babyName.charAt(0) %><span><%= _babyName.slice(1) %></span>.fyi</span></a>
      <% if (typeof viewer !== 'undefined' && viewer) { %>
      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/journey">Journey</a>
        <a href="/milestones">Milestones</a>
        <a href="/vitals">Vitals</a>
        <% if (typeof authenticated !== 'undefined' && authenticated) { %>
          <a href="/admin" class="nav-admin">Dashboard</a>
        <% } %>
        <a href="/admin/logout">Logout</a>
        <button id="notifToggle" class="notif-toggle" aria-label="Toggle notifications" style="display:none" title="Notifications">
          <svg class="notif-bell" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
          </svg>
          <span class="notif-dot" id="notifDot"></span>
        </button>
      </div>
      <button class="nav-toggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <% } %>
    </nav>
  </header>
  <main>
