<%- include('partials/head', { pageTitle: update.title }) %>

<section class="single-update">
  <a href="/updates" class="back-link" id="backLink">&larr; Back to all updates</a>
  <script>
  (function() {
    var link = document.getElementById('backLink');
    var ref = document.referrer;
    if (ref && (ref.indexOf('/updates') !== -1 || ref.indexOf('/#update-') !== -1 || ref.match(/\/$/))) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        history.back();
      });
    }
  })();
  </script>

  <article>
    <div class="update-meta">
      <span class="mood mood-<%= update.mood %>"><%= update.mood === 'great' ? 'Great day' : update.mood === 'good' ? 'Good day' : 'Tough day' %></span>
      <time><%= new Date(update.update_date || update.created_at).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></time>
    </div>

    <h1><%= update.title %></h1>

    <% if (photos && photos.length > 0) { %>
    <div class="update-photos-gallery">
      <% photos.forEach(function(p) { %>
      <div class="update-photo full">
        <img src="<%= p.photo %>" alt="<%= update.title %>">
      </div>
      <% }); %>
    </div>
    <% } else if (update.photo) { %>
    <div class="update-photo full">
      <img src="<%= update.photo %>" alt="<%= update.title %>">
    </div>
    <% } %>

    <div class="update-content">
      <%- update.content.replace(/\n/g, '<br>') %>
    </div>
  </article>

  <nav class="update-nav">
    <% if (prev) { %>
      <a href="/update/<%= prev.id %>" class="update-nav-link prev">
        <span class="update-nav-label">&larr; Previous day</span>
        <span class="update-nav-title"><%= prev.title %></span>
      </a>
    <% } else { %>
      <span class="update-nav-link disabled"></span>
    <% } %>
    <% if (next) { %>
      <a href="/update/<%= next.id %>" class="update-nav-link next">
        <span class="update-nav-label">Next day &rarr;</span>
        <span class="update-nav-title"><%= next.title %></span>
      </a>
    <% } else { %>
      <span class="update-nav-link disabled"></span>
    <% } %>
  </nav>
</section>

<%- include('partials/footer') %>
