ADMIN_PASSWORD=your-secure-password-here
VIEWER_PASSWORD=your-viewer-password-here
SESSION_SECRET=your-random-session-secret-here
PORT=3000

# Web Push VAPID keys (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Database — Turso (production) or local SQLite (dev)
# For local dev, leave as-is (uses file:./data/babyjourney.db by default)
# For Turso: get your URL and token from https://turso.tech
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Image storage — Cloudinary (production) or local disk (dev)
# For local dev, leave blank (uploads go to public/uploads/)
# For Cloudinary: get credentials from https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
